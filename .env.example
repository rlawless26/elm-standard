# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Resend — resend.com (verify the elmstandard.com domain first)
RESEND_API_KEY=
RESEND_FROM="Elm Standard <rob@elmstandard.com>"
QUOTES_TO_EMAIL=rob@elmstandard.com

# /admin gate. ADMIN_TOKEN is the cookie value — generate with `openssl rand -hex 32`.
ADMIN_PASSWORD=
ADMIN_TOKEN=

# Used in the notification email's admin link and the logout redirect.
# In dev: http://localhost:3000 — in prod: https://elmstandard.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000
